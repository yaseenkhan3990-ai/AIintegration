<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CashBot – Smart Business Deals</title>

  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Google AdSense -->
  <script async
    src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX"
    crossorigin="anonymous"></script>
</head>

<body class="bg-slate-50 text-slate-800">

<!-- ===== TOP AD ===== -->

<!-- ===== HEADER ===== -->
<header class="max-w-7xl mx-auto px-4 py-6 flex justify-between items-center">
  <h1 class="text-2xl font-bold text-blue-900">CashBot</h1>
  <nav class="hidden md:flex gap-6 text-sm font-medium">
    <a href="#" class="hover:text-blue-700">Home</a>
    <a href="#" class="hover:text-blue-700">Offers</a>
    <a href="#" class="hover:text-blue-700">About</a>
    <a href="#" class="hover:text-blue-700">Contact</a>
  </nav>
</header>

<!-- ===== MAIN LAYOUT ===== -->
<section class="max-w-7xl mx-auto px-4 py-12
                grid grid-cols-1 lg:grid-cols-[1fr_3fr_1fr] gap-6">

  <!-- LEFT AD -->
  <aside class="hidden lg:block">
    <div class="bg-white border rounded-lg p-4 shadow-sm h-full flex items-center justify-center">
      <ins class="adsbygoogle"
           style="display:block"
           data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
           data-ad-slot="2222222222"
           data-ad-format="auto"></ins>
      <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </div>
  </aside>

  <!-- CENTER CONTENT -->
  <main class="bg-white rounded-2xl shadow-lg p-10 md:p-14 text-center">

    <!-- HERO -->
    <h2 class="text-3xl md:text-5xl font-bold text-blue-900 mb-6">
      Smart Deals for Smart Businesses
    </h2>
    <p class="text-gray-600 max-w-2xl mx-auto mb-10">
      CashBot helps you discover verified, high-value sponsored offers.
      Simple. Transparent. Business-ready.
    </p>
    <form action='/bot/payment/' method="post">
    <input type="hidden" name="token" value="<%= chatId %>">
    <button type="submit"
       class="inline-block bg-blue-900 hover:bg-black transition
              text-white px-10 py-4 rounded-xl font-semibold shadow-md">
      Explore Offers
    </button>
    </form>
    <!-- FEATURES -->
    <div class="grid md:grid-cols-3 gap-8 mt-14 text-left">
      <div>
        <h3 class="font-semibold text-lg mb-2">Trusted Partners</h3>
        <p class="text-sm text-gray-600">
          We work only with verified advertisers to ensure quality and safety.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-lg mb-2">Transparent Ads</h3>
        <p class="text-sm text-gray-600">
          Clear sponsored labels with no hidden redirections or tricks.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-lg mb-2">Real Business Value</h3>
        <p class="text-sm text-gray-600">
          Offers designed to help businesses save money and grow faster.
        </p>
      </div>
    </div>

  </main>

  <!-- RIGHT AD -->
  <aside class="hidden lg:block">
    <div class="bg-white border rounded-lg p-4 shadow-sm h-full flex items-center justify-center">
      <ins class="adsbygoogle"
           style="display:block"
           data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
           data-ad-slot="3333333333"
           data-ad-format="auto"></ins>
      <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </div>
  </aside>

</section>

<!-- ===== BOTTOM AD ===== -->
<div class="max-w-7xl mx-auto px-4 pb-10">
  <div class="bg-white border rounded-lg p-3 text-center shadow-sm">
    <span class="text-xs text-gray-400 block mb-1">Advertisement</span>
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
         data-ad-slot="4444444444"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>
</div>

<!-- ===== FOOTER ===== -->
 
<footer class="bg-slate-900 text-slate-300 text-sm">
  <div class="max-w-7xl mx-auto px-4 py-6 text-center">
    © 2026 <span class="font-semibold text-white">CashBot</span> · Sponsored Business Content
  </div>
</footer>

</body>
</html>
