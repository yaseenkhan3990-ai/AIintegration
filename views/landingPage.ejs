<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CashBot</title>

  <!-- Tailwind -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- AdSense -->
  <script async
    src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX"
    crossorigin="anonymous"></script>
</head>

<body class="bg-[#0a1833] text-white min-h-screen flex flex-col">

<!-- TOP AD -->
<div class="w-full px-3 pt-3">
  <div class="bg-white rounded-lg p-3 text-center">
    <span class="text-xs text-gray-400 block mb-1">Sponsored</span>
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
         data-ad-slot="1111111111"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>
</div>

<!-- MAIN AREA -->
<div class="flex-1 w-full max-w-7xl mx-auto px-3 py-6
            grid grid-cols-1 lg:grid-cols-[1fr_3fr_1fr] gap-4">

  <!-- LEFT AD (desktop only) -->
  <aside class="hidden lg:flex bg-white rounded-lg p-3 items-center justify-center">
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
         data-ad-slot="2222222222"
         data-ad-format="auto"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </aside>

  <!-- CENTER CONTENT -->
  <main class="bg-white rounded-xl p-8 md:p-12 text-center
               flex flex-col justify-center items-center">
    <h1 class="text-2xl md:text-4xl font-bold mb-4">
      Smart Deals. Real Value.
    </h1>
    <p class="text-black mb-8 max-w-xl">
      Discover trusted sponsored offers selected for you. Simple, safe and transparent.
    </p>
    <a href="#"
       class="bg-blue-900 hover:bg-blue-700 transition px-8 py-3 rounded-lg font-semibold">
      Explore Now
    </a>
  </main>

  <!-- RIGHT AD (desktop only) -->
  <aside class="hidden lg:flex bg-white rounded-lg p-3 items-center justify-center">
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
         data-ad-slot="3333333333"
         data-ad-format="auto"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </aside>

</div>

<!-- BOTTOM AD -->
<div class="w-full px-3 pb-6">
  <div class="bg-white rounded-lg p-3 text-center">
    <span class="text-xs text-gray-400 block mb-1">Advertisement</span>
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
         data-ad-slot="4444444444"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>
</div>

<footer class="text-center text-sm text-blue-300 pb-6">
  © 2026 CashBot · Sponsored Content
</footer>

</body>
</html>
