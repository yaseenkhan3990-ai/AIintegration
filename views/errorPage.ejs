<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Oops! Page Not Found</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-br from-indigo-100 to-purple-200 min-h-screen flex items-center justify-center">

  <div class="bg-white p-10 rounded-3xl shadow-2xl text-center max-w-lg">
    
    <!-- Cartoon SVG -->
    <div class="flex justify-center mb-6">
      <svg width="180" height="180" viewBox="0 0 200 200" fill="none">
        <circle cx="100" cy="100" r="90" fill="#E0E7FF"/>
        <circle cx="70" cy="85" r="12" fill="#4F46E5"/>
        <circle cx="130" cy="85" r="12" fill="#4F46E5"/>
        <path d="M70 125 Q100 150 130 125" stroke="#4F46E5" stroke-width="6" fill="none"/>
        <text x="50%" y="180" text-anchor="middle" fill="#4F46E5" font-size="28" font-weight="bold">
        
        </text>
      </svg>
    </div>

    <h1 class="text-3xl font-bold text-indigo-600 mb-2">
      Oops! Link not found
    </h1>

    <p class="text-gray-600 mb-6">
      The page you are looking for took a little night walk 🌙  
      and didn’t come back.
    </p>

    <a href="/" class="inline-block bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-full shadow-lg transition">
      Go Back Home
    </a>

  </div>

</body>
</html>
